NODE_ENV=development
PORT=3000

# MongoDB Database
MONGODB_URI=mongodb+srv://kartiPChess:kartiChess%402026@cluster-001.6pvjgt0.mongodb.net/kpcomm?retryWrites=true&w=majority


# JWT Configuration
